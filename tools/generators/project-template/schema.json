{
  "$schema": "https://json-schema.org/schema",
  "$id": "ProjectTemplateGenerator",
  "title": "Project template generator",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name used for filesystem paths, package names, and project ids.",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Product name"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
