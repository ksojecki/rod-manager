{
  "name": "@rod-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "node ./node_modules/nx/bin/nx.js run-many -t lint",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "postinstall": "node ./node_modules/husky/bin.js"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nx/eslint": "22.5.4",
    "@nx/js": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^56.1.2",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.0",
    "lint-staged": "^16.1.6",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript-eslint": "^8.43.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}": [
      "node ./node_modules/eslint/bin/eslint.js --fix --max-warnings=0 --no-warn-ignored --ignore-pattern eslint.config.mjs",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,jsonc,md,yml,yaml,css,scss,html}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
