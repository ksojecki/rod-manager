{
  "name": "@rod-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "node ./node_modules/nx/bin/nx.js run-many -t lint",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "postinstall": "node ./node_modules/husky/bin.js"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nx/esbuild": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/node": "^22.5.4",
    "@nx/react": "^22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/web": "22.5.4",
    "@react-router/dev": "^7.12.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "ajv": "^8.0.0",
    "esbuild": "^0.19.2",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "^56.1.2",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.4.0",
    "lint-staged": "^16.1.6",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.43.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}": [
      "node ./node_modules/eslint/bin/eslint.js --fix --max-warnings=0 --no-warn-ignored --ignore-pattern eslint.config.mjs",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,jsonc,md,yml,yaml,css,scss,html}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "dependencies": {
    "@fastify/autoload": "~6.0.3",
    "@fastify/sensible": "~6.0.2",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "fastify": "~5.2.1",
    "fastify-plugin": "~5.0.1",
    "isbot": "^4.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
