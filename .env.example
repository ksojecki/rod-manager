# Copy this file to .env and fill in the values for your local environment.
# Do NOT commit .env — it contains secrets.

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=localhost
PORT=3000
NODE_ENV=development
SESSION_COOKIE_SECRET=change-me

# TLS certificates (generated by `npm run setup-dev-certs`)
HTTPS_KEY_PATH=.cert/localhost-key.pem
HTTPS_CERT_PATH=.cert/localhost-cert.pem

# ─── Database seeding ─────────────────────────────────────────────────────────
# Seed the local database with the initial user on startup.
# The initial user is assigned the administrator role.
AUTH_SEED_INITIAL_USER=true
AUTH_INITIAL_USER_EMAIL=admin@rod-manager.local
AUTH_INITIAL_USER_PASSWORD=admin1234

# ─── OAuth ─────────────────────────────────────────────────────────────────────
# Base URL that OAuth providers will redirect to after authorization.
# Must match the Redirect URI configured in each provider's developer console.
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Google OAuth 2.0
# https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Apple Sign In
# https://developer.apple.com/account/resources/identifiers/list/serviceId
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_TEAM_ID=

# Facebook / Meta
# https://developers.facebook.com/apps/
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=

