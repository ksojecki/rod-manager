{
  "name": "@rod-manager/web",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/web",
          "command": "node ../../node_modules/typescript/bin/tsc --build --emitDeclarationOnly"
        }
      },
      "build-server": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/dist/packages/web/server"
        ],
        "options": {
          "cwd": "packages/web",
          "command": "node ../../node_modules/vite/bin/vite.js build --ssr src/entry-server.tsx --outDir ../../dist/packages/web/server"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/web",
          "command": "node ../../node_modules/vitest/vitest.mjs run --config vite.config.mts"
        }
      }
    }
  }
}
